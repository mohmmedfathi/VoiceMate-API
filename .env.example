# Required: secret used to sign JWTs. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Auth
JWT_EXPIRES_MINUTES=1440

# Storage and Celery broker
DATABASE_URL=sqlite:///./voicemate.db
REDIS_URL=redis://localhost:6379/0
# Run Celery tasks inline without a broker/worker (development only)
CELERY_TASK_ALWAYS_EAGER=0

# Transcription
UPLOAD_DIR=uploads
# Model size: tiny/base/small/medium/large-v3. Use "medium" or "large-v3" for
# good Arabic accuracy ("small" is weak on Arabic). Larger = slower + bigger download.
WHISPER_MODEL=small
# Force a language ("ar", "en", …) for short/accented clips; empty = auto-detect.
WHISPER_LANGUAGE=

# Summary (optional): set a Google Gemini key for AI summaries.
# Leave GEMINI_API_KEY empty to use the built-in local summarizer instead.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
